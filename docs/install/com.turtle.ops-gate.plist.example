<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.turtle.ops-gate</string>
    <key>ProgramArguments</key>
    <array>
        <string>/Users/turtle/turtleos/venv/bin/python3</string>
        <string>/Users/turtle/turtleos/scripts/ops_runner.py</string>
        <string>--job</string>
        <string>scheduled</string>
    </array>
    <key>WorkingDirectory</key>
    <string>/Users/turtle/turtleos</string>
    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin</string>
        <key>DOTENV_PATH</key>
        <string>/Users/turtle/turtleos/.env</string>
    </dict>
    <key>StandardOutPath</key>
    <string>/Users/turtle/turtleos/logs/ops-gate.log</string>
    <key>StandardErrorPath</key>
    <string>/Users/turtle/turtleos/logs/ops-gate.log</string>
    <key>StartCalendarInterval</key>
    <dict>
        <key>Hour</key>
        <integer>4</integer>
        <key>Minute</key>
        <integer>15</integer>
    </dict>
</dict>
</plist>
