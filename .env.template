# turtleOS environment template
# Copy to .env and fill local values. Never commit real secrets.

# Required for Discord runtime
DISCORD_BOT_TOKEN=
DISCORD_CHANNEL_DIALOGUE=

# Conversation backend
# Use a claude-* model with ANTHROPIC_API_KEY for highest-quality dialogue,
# or an Ollama model name for local-only operation.
DIALOGUE_MODEL=claude-sonnet-4-6
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# Local model pipeline
OLLAMA_URL=http://localhost:11434
TRIAGE_MODEL=qwen3.5:0.8b
CONSUL_MODEL=qwen3.5:9b
SCOUT_MODEL=qwen3.5:9b
REFLECTION_MODEL=qwen3.5:27b
EDIT_DELEGATE_MODEL=qwen3.5:4b

# Optional practice links and operators
PRACTICE_TIMEZONE=Europe/Berlin
OBSIDIAN_VAULT=magic-practice
PRACTICE_WEB_BASE=
WORKSHOP_URL=
TURTLE_SHELL_TOKEN=

# Optional services / integrations
TWITTER_CONSUMER_KEY=
TWITTER_CONSUMER_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_TOKEN_SECRET=
TWITTER_AUTH_TOKEN=
TWITTER_CT0=
INTAKE_PORT=8742
INTAKE_PUBLIC_URL=
