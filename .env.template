# turtleOS environment template
# Copy to .env and fill local values. Never commit real secrets.

# Required for Discord runtime
DISCORD_BOT_TOKEN=
# Optional: separate River bot identity (native attunement — TURTLE_SPEC §5.8)
# When set, river_bot.py handles acts in the main channel; Turtle speaks in eddies only.
RIVER_BOT_TOKEN=
DISCORD_CHANNEL_DIALOGUE=

# Conversation backend (TURTLE_SPEC §8.3 — local-first default)
# Vanilla: set DIALOGUE_MODEL to an Ollama model; leave ANTHROPIC_API_KEY empty.
# Cloud: opt-in — set ANTHROPIC_API_KEY and a claude-* DIALOGUE_MODEL.
DIALOGUE_MODEL=gemma3:27b
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# Local model pipeline
OLLAMA_URL=http://localhost:11434
TRIAGE_MODEL=qwen3.5:4b
REFLECTION_MODEL=qwen3.5:27b
EDIT_DELEGATE_MODEL=qwen3.5:4b
# Target (post-migration): RIVER_MODEL, TURTLE_MODEL — see TURTLE_SPEC §5.7, §7.4
RIVER_MODEL=qwen3.5:4b
TURTLE_MODEL=qwen3.5:9b

# Optional practice links and operators
PRACTICE_TIMEZONE=Europe/Berlin
OBSIDIAN_VAULT=magic-practice
PRACTICE_WEB_BASE=
WORKSHOP_URL=
TURTLE_SHELL_TOKEN=

# Optional services / integrations
TWITTER_CONSUMER_KEY=
TWITTER_CONSUMER_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_TOKEN_SECRET=
TWITTER_AUTH_TOKEN=
TWITTER_CT0=
INTAKE_PORT=8742
INTAKE_PUBLIC_URL=
