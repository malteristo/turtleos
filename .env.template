# turtleOS environment template
# Copy to .env and fill local values. Never commit real secrets.

# Required for Discord runtime
DISCORD_BOT_TOKEN=
# Optional: separate River bot identity (native attunement — TURTLE_SPEC §5.8)
# When set, river_bot.py handles acts in the main channel; Turtle speaks in eddies only.
RIVER_BOT_TOKEN=
# Optional: Turtle bot user id for River add_user handoff (auto-cached on Turtle startup)
TURTLE_BOT_USER_ID=
DISCORD_CHANNEL_DIALOGUE=

# ─── Two-stack model routing (TURTLE_SPEC §8.1) ─────────────────
# River: Qwen — fast local acts, triage, reflection, background work
# Turtle: Gemma — capable local eddy dialogue
# See models.py and ARCHITECTURE.md § LLM Backend Selection

OLLAMA_URL=http://localhost:11434

# River stack (Qwen)
RIVER_MODEL=qwen3.5:4b
TRIAGE_MODEL=qwen3.5:0.8b
REFLECTION_MODEL=qwen3.5:27b
EDIT_DELEGATE_MODEL=qwen3.5:4b

# Turtle stack (Gemma)
TURTLE_MODEL=gemma4:31b

# Magic-attuned main channel + legacy "local" alias (!thread without --model)
# Defaults to TURTLE_MODEL when unset. Native attunement uses TURTLE_MODEL for eddies.
DIALOGUE_MODEL=gemma4:31b

# ─── Optional API opt-in (TURTLE_SPEC §8.3) ─────────────────────
# Cloud dialogue: set ANTHROPIC_API_KEY and DIALOGUE_MODEL=claude-sonnet-4-6
# Per-thread override: !thread "topic" --model claude|gemini|gemma-26b
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# Optional practice links and operators
PRACTICE_TIMEZONE=Europe/Berlin
OBSIDIAN_VAULT=magic-practice
PRACTICE_WEB_BASE=
WORKSHOP_URL=
TURTLE_SHELL_TOKEN=

# Optional services / integrations
TWITTER_CONSUMER_KEY=
TWITTER_CONSUMER_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_TOKEN_SECRET=
TWITTER_AUTH_TOKEN=
TWITTER_CT0=
INTAKE_PORT=8742
INTAKE_PUBLIC_URL=
